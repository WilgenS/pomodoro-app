import { Controller, Get, Post, Delete, Param } from '@nestjs/common';

@Controller('badges')
export class BadgesController {
  @Get()
  getAllBadges(): string {
    return 'This action returns all badges';
  }

  @Post()
  createBadge(): string {
    return 'This action creates a new badge';
  }

  @Get(':id')
  getBadgeById(@Param('id') id: string): string {
    return `This action returns badge #${id}`;
  }

  @Delete(':id')
  deleteBadge(@Param('id') id: string): string {
    return `This action removes badge #${id}`;
  }
}

