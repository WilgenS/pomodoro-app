# Environment setup for Pomodoro Application Backend
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/pomodoro?schema=public"

# Google OAuth Configuration
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

# JWT Authentication
JWT_ACCESS_SECRET="super-secret-access-key-change-me"
JWT_REFRESH_SECRET="super-secret-refresh-key-change-me"

# Frontend URL (For OAuth Redirects)
FRONTEND_URL="http://localhost:5173"
